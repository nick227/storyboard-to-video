# This runtime is intentionally separate from apps/web and the production LTX server.
LTX_KEYFRAMES_BACKEND=dry-run
LTX_KEYFRAMES_TOKEN=
LTX_KEYFRAMES_INPUT_ROOT=./fixtures
LTX_KEYFRAMES_OUTPUT_ROOT=./artifacts

# Required only when LTX_KEYFRAMES_BACKEND=official-cli.
LTX_REPO_PATH=/absolute/path/to/LTX-Video
LTX_PYTHON=/absolute/path/to/LTX-Video/env/bin/python
LTX_PIPELINE_CONFIG=configs/ltxv-13b-0.9.8-distilled.yaml
