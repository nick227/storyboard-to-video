generator client {
  provider               = "prisma-client"
  output                 = "../src/generated/prisma"
  runtime                = "nodejs"
  moduleFormat           = "cjs"
  generatedFileExtension = "ts"
  importFileExtension    = ""
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @db.Uuid
  email              String              @unique
  displayName        String              @map("display_name")
  passwordHash       String              @map("password_hash")
  status             String              @default("active")
  platformRole       String              @default("user") @map("platform_role")
  mediaDefaults      Json?               @map("media_defaults")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  memberships        Membership[]
  sessions           Session[]
  projects           Project[]           @relation("ProjectCreator")
  jobs               GenerationJob[]
  assets             Asset[]
  idempotency        IdempotencyRecord[]
  generationRequests GenerationRequest[]
  usageEvents        UsageEvent[]
  creditReservations CreditReservation[]
  creditLedger       CreditLedgerEntry[]
  chargingChanges    CreditAccount[]      @relation("CreditAccountChargingChangedBy")
  purchasedSales     CreditSale[]         @relation("CreditSaleCustomer")
  recordedSales      CreditSale[]         @relation("CreditSaleRecorder")
  paymentCustomers   PaymentCustomer[]
  checkoutAttempts   CheckoutAttempt[]
  welcomePoliciesCreated WelcomeCreditPolicyVersion[] @relation("WelcomeCreditPolicyCreator")
  adminAuditEvents   AdminAuditEvent[]    @relation("AdminAuditActor")
  videoGenerationAttempts VideoGenerationAttempt[]

  @@map("users")
}

model Workspace {
  id                 String              @id @db.Uuid
  name               String
  type               String              @default("personal")
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  memberships        Membership[]
  sessions           Session[]
  projects           Project[]
  jobs               GenerationJob[]
  assets             Asset[]
  idempotency        IdempotencyRecord[]
  generationCacheEntries GenerationCacheEntry[]
  tombstones         ProjectTombstone[]
  generationRequests GenerationRequest[]
  usageEvents        UsageEvent[]
  creditAccount      CreditAccount?
  creditReservations CreditReservation[]
  creditLedger       CreditLedgerEntry[]
  creditSales        CreditSale[]
  paymentCustomers   PaymentCustomer[]
  checkoutAttempts   CheckoutAttempt[]
  adminAuditEvents   AdminAuditEvent[]
  videoGenerationAttempts VideoGenerationAttempt[]

  @@map("workspaces")
}

model Membership {
  userId    String    @map("user_id") @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  role      String    @default("owner")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@id([userId, tenantId])
  @@index([tenantId])
  @@map("workspace_memberships")
}

model Session {
  id        String    @id @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.Char(64)
  userId    String    @map("user_id") @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@map("sessions")
}

model Project {
  id              String              @id @db.VarChar(80)
  tenantId        String              @map("tenant_id") @db.Uuid
  createdByUserId String              @map("created_by_user_id") @db.Uuid
  title           String
  revision        Int
  incarnationId   String              @map("incarnation_id") @db.Uuid
  document        Json
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant          Workspace           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy       User                @relation("ProjectCreator", fields: [createdByUserId], references: [id], onDelete: Restrict)
  jobs            GenerationJob[]
  assets          Asset[]
  idempotency     IdempotencyRecord[]
  videoGenerationAttempts VideoGenerationAttempt[]

  @@index([tenantId, updatedAt])
  @@map("projects")
}

model GenerationJob {
  id             String     @id @db.Uuid
  projectId      String?    @map("project_id") @db.VarChar(80)
  sceneId        String?    @map("scene_id")
  tenantId       String?    @map("tenant_id") @db.Uuid
  userId         String?    @map("user_id") @db.Uuid
  type           String
  status         String
  idempotencyKey String?    @map("idempotency_key")
  result         Json?
  error          Json?
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  startedAt      DateTime?  @map("started_at") @db.Timestamptz(3)
  finishedAt     DateTime?  @map("finished_at") @db.Timestamptz(3)
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tenant         Workspace? @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  videoGenerationAttempts VideoGenerationAttempt[]

  @@index([projectId, createdAt])
  @@index([tenantId, status])
  @@map("generation_jobs")
}

model VideoGenerationAttempt {
  id                    String         @id @db.Uuid
  generationJobId       String?        @map("generation_job_id") @db.Uuid
  generationRequestId   String?        @unique @map("generation_request_id") @db.Uuid
  tenantId              String?        @map("tenant_id") @db.Uuid
  userId                String?        @map("user_id") @db.Uuid
  projectId             String?        @map("project_id") @db.VarChar(80)
  sceneId               String?        @map("scene_id")
  provider              String
  model                 String
  generationMode        String         @map("generation_mode")
  requestSnapshot       Json           @map("request_snapshot")
  requestFingerprint    String?        @map("request_fingerprint") @db.VarChar(64)
  providerTaskId        String?        @map("provider_task_id")
  providerSubmittedAt   DateTime?      @map("provider_submitted_at") @db.Timestamptz(3)
  lifecycleState        String         @map("lifecycle_state")
  pollAfter             DateTime?      @map("poll_after") @db.Timestamptz(3)
  retryCount            Int            @default(0) @map("retry_count")
  cancellationState     String         @default("not_requested") @map("cancellation_state")
  inputHashes           Json           @map("input_hashes")
  providerOutputId      String?        @map("provider_output_id")
  outputExpiresAt       DateTime?      @map("output_expires_at") @db.Timestamptz(3)
  downloadState         String         @default("pending") @map("download_state")
  commitState           String         @default("pending") @map("commit_state")
  costReferences        Json?          @map("cost_references")
  error                 Json?
  createdAt             DateTime       @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt             DateTime       @updatedAt @map("updated_at") @db.Timestamptz(3)
  completedAt           DateTime?      @map("completed_at") @db.Timestamptz(3)
  generationJob         GenerationJob? @relation(fields: [generationJobId], references: [id], onDelete: SetNull)
  generationRequest     GenerationRequest? @relation(fields: [generationRequestId], references: [id], onDelete: SetNull)
  tenant                Workspace?     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                  User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  project               Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([lifecycleState, pollAfter])
  @@index([tenantId, createdAt])
  @@index([projectId, sceneId, createdAt])
  @@index([provider, providerTaskId])
  @@map("video_generation_attempts")
}

model Asset {
  id         String    @id @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  projectId  String    @map("project_id") @db.VarChar(80)
  type       String
  fileName   String    @map("file_name")
  storageKey String    @unique @map("storage_key")
  publicPath String    @unique @map("public_path")
  mimeType   String?   @map("mime_type")
  byteSize   BigInt    @map("byte_size")
  status     String    @default("committed")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(3)
  tenant     Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, type, fileName])
  @@index([tenantId, createdAt])
  @@index([projectId, status])
  @@map("assets")
}

model IdempotencyRecord {
  id           String    @id @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  projectId    String    @map("project_id") @db.VarChar(80)
  key          String
  payloadHash  String    @map("payload_hash") @db.Char(64)
  status       String
  jobId        String?   @map("job_id") @db.Uuid
  statusCode   Int?      @map("status_code")
  responseBody Json?     @map("response_body")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  finishedAt   DateTime? @map("finished_at") @db.Timestamptz(3)
  tenant       Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([tenantId, status])
  @@map("idempotency_records")
}

// Exact-input reuse cache for LLM-backed narration/prompt generation only — distinct from
// IdempotencyRecord above, which exists purely for safe request retries. Append-only per
// (tenantId, fingerprintHash): a lookup takes the newest row, and an explicit "generate a new
// variation" (bypassed=true) writes a NEW row rather than overwriting the one it bypassed, so a
// prior reusable result is never destroyed by requesting a fresh one.
model GenerationCacheEntry {
  id                    String    @id @db.Uuid
  tenantId              String    @map("tenant_id") @db.Uuid
  operation             String
  fingerprintHash       String    @map("fingerprint_hash") @db.Char(64)
  provider              String
  model                 String?
  promptTemplateVersion Int       @map("prompt_template_version")
  sourceDigest          String    @map("source_digest") @db.Char(64)
  result                Json
  bypassed              Boolean   @default(false)
  // Set only on a cache-hit row: which prior entry this request reused. A hit still writes its own
  // row (this one) so every served request is auditable — who reused what, when — without that
  // audit trail requiring a new provider call or duplicating provider-cost bookkeeping.
  servedFromEntryId     String?   @map("served_from_entry_id") @db.Uuid
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  tenant                Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, fingerprintHash, createdAt])
  @@map("generation_cache_entries")
}

model ProjectTombstone {
  projectId     String    @id @map("project_id") @db.VarChar(80)
  tenantId      String    @map("tenant_id") @db.Uuid
  incarnationId String    @map("incarnation_id") @db.Uuid
  deletedAt     DateTime  @default(now()) @map("deleted_at") @db.Timestamptz(3)
  tenant        Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, deletedAt])
  @@map("project_tombstones")
}

model GenerationRequest {
  id                String      @id @db.Uuid
  tenantId          String      @map("tenant_id") @db.Uuid
  userId            String?     @map("user_id") @db.Uuid
  projectId         String?     @map("project_id") @db.VarChar(80)
  sceneId           String?     @map("scene_id")
  jobId             String?     @map("job_id") @db.Uuid
  idempotencyKey    String?     @map("idempotency_key")
  sequence          Int
  modality          String
  provider          String
  model             String
  status            String
  inputMetadata     Json?       @map("input_metadata")
  outputMetadata    Json?       @map("output_metadata")
  providerRequestId String?     @map("provider_request_id")
  error             Json?
  startedAt         DateTime    @default(now()) @map("started_at") @db.Timestamptz(3)
  completedAt       DateTime?   @map("completed_at") @db.Timestamptz(3)
  tenant            Workspace   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user              User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  usageEvent        UsageEvent?
  costSnapshot      ProviderCostSnapshot?
  creditReservation CreditReservation?
  videoGenerationAttempt VideoGenerationAttempt?

  @@unique([jobId, sequence])
  @@index([tenantId, startedAt])
  @@index([projectId, startedAt])
  @@index([provider, model, startedAt])
  @@map("generation_requests")
}

model UsageEvent {
  id                  String            @id @db.Uuid
  generationRequestId String            @unique @map("generation_request_id") @db.Uuid
  tenantId            String            @map("tenant_id") @db.Uuid
  userId              String?           @map("user_id") @db.Uuid
  projectId           String?           @map("project_id") @db.VarChar(80)
  sceneId             String?           @map("scene_id")
  jobId               String?           @map("job_id") @db.Uuid
  modality            String
  provider            String
  model               String
  providerRequestId   String?           @map("provider_request_id")
  usage               Json
  rawUsage            Json?             @map("raw_usage")
  measurementStatus   String            @map("measurement_status")
  occurredAt          DateTime          @default(now()) @map("occurred_at") @db.Timestamptz(3)
  generationRequest   GenerationRequest @relation(fields: [generationRequestId], references: [id], onDelete: Cascade)
  tenant              Workspace         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  costSnapshot        ProviderCostSnapshot?

  @@index([tenantId, occurredAt])
  @@index([projectId, occurredAt])
  @@index([provider, model, occurredAt])
  @@map("usage_events")
}

model ProviderPriceVersion {
  id                  String                 @id @db.Uuid
  versionKey          String                 @unique @map("version_key")
  provider            String
  modality            String
  model               String
  currency            String                 @default("USD") @db.Char(3)
  rateCard             Json                   @map("rate_card")
  reservationNanoUsd  BigInt                 @map("reservation_nano_usd")
  evidenceStatus      String                 @map("evidence_status")
  reconciledAt        DateTime?              @map("reconciled_at") @db.Timestamptz(3)
  reconciliationNotes String?                @map("reconciliation_notes")
  sourceReference     String?                @map("source_reference")
  billable            Boolean                @default(false)
  active              Boolean                @default(false)
  effectiveAt         DateTime               @default(now()) @map("effective_at") @db.Timestamptz(3)
  retiredAt           DateTime?              @map("retired_at") @db.Timestamptz(3)
  createdAt           DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  costSnapshots       ProviderCostSnapshot[]
  reservations        CreditReservation[]

  @@index([provider, modality, model, active])
  @@map("provider_price_versions")
}

model MarkupPolicyVersion {
  id                String              @id @db.Uuid
  versionKey        String              @unique @map("version_key")
  name              String
  markupBasisPoints Int                 @map("markup_basis_points")
  fixedNanoUsd      BigInt              @default(0) @map("fixed_nano_usd")
  active            Boolean             @default(false)
  effectiveAt       DateTime            @default(now()) @map("effective_at") @db.Timestamptz(3)
  retiredAt         DateTime?           @map("retired_at") @db.Timestamptz(3)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  reservations      CreditReservation[]

  @@index([active, effectiveAt])
  @@map("markup_policy_versions")
}

model SiteCreditRateVersion {
  id                   String              @id @db.Uuid
  versionKey           String              @unique @map("version_key")
  nanoUsdPerSiteCredit BigInt              @map("nano_usd_per_site_credit")
  active               Boolean             @default(false)
  effectiveAt          DateTime            @default(now()) @map("effective_at") @db.Timestamptz(3)
  retiredAt            DateTime?           @map("retired_at") @db.Timestamptz(3)
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  reservations         CreditReservation[]

  @@index([active, effectiveAt])
  @@map("site_credit_rate_versions")
}

model WelcomeCreditPolicyVersion {
  id                   String              @id @db.Uuid
  versionKey           String              @unique @map("version_key")
  name                 String
  creditMicros         BigInt              @map("credit_micros")
  active               Boolean             @default(false)
  effectiveAt          DateTime            @default(now()) @map("effective_at") @db.Timestamptz(3)
  retiredAt            DateTime?           @map("retired_at") @db.Timestamptz(3)
  createdByAdminId     String?             @map("created_by_admin_id") @db.Uuid
  createdAt            DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  createdByAdmin       User?               @relation("WelcomeCreditPolicyCreator", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  ledgerEntries        CreditLedgerEntry[]

  @@index([active, effectiveAt])
  @@map("welcome_credit_policy_versions")
}

model ProviderCostSnapshot {
  id                     String               @id @db.Uuid
  generationRequestId    String               @unique @map("generation_request_id") @db.Uuid
  usageEventId           String               @unique @map("usage_event_id") @db.Uuid
  providerPriceVersionId String               @map("provider_price_version_id") @db.Uuid
  usageSnapshot          Json                 @map("usage_snapshot")
  rateCardSnapshot       Json                 @map("rate_card_snapshot")
  providerCostNanoUsd    BigInt               @map("provider_cost_nano_usd")
  currency               String               @db.Char(3)
  calculation            Json
  createdAt              DateTime             @default(now()) @map("created_at") @db.Timestamptz(3)
  generationRequest      GenerationRequest    @relation(fields: [generationRequestId], references: [id], onDelete: Restrict)
  usageEvent             UsageEvent           @relation(fields: [usageEventId], references: [id], onDelete: Restrict)
  providerPriceVersion   ProviderPriceVersion @relation(fields: [providerPriceVersionId], references: [id], onDelete: Restrict)
  reservation            CreditReservation?

  @@index([providerPriceVersionId, createdAt])
  @@map("provider_cost_snapshots")
}

model CreditAccount {
  id                       String              @id @db.Uuid
  tenantId                 String              @unique @map("tenant_id") @db.Uuid
  availableCreditMicros    BigInt              @default(0) @map("available_credit_micros")
  reservedCreditMicros     BigInt              @default(0) @map("reserved_credit_micros")
  chargingEnabled          Boolean             @default(false) @map("charging_enabled")
  chargingChangedAt        DateTime?           @map("charging_changed_at") @db.Timestamptz(3)
  chargingChangedByUserId  String?             @map("charging_changed_by_user_id") @db.Uuid
  createdAt                DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt                DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant                   Workspace           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  chargingChangedBy        User?               @relation("CreditAccountChargingChangedBy", fields: [chargingChangedByUserId], references: [id], onDelete: SetNull)
  ledgerEntries            CreditLedgerEntry[]

  @@index([chargingEnabled])
  @@map("credit_accounts")
}

model CreditReservation {
  id                         String                 @id @db.Uuid
  generationRequestId        String                 @unique @map("generation_request_id") @db.Uuid
  tenantId                   String                 @map("tenant_id") @db.Uuid
  userId                     String?                @map("user_id") @db.Uuid
  providerPriceVersionId     String?                @map("provider_price_version_id") @db.Uuid
  markupPolicyVersionId      String?                @map("markup_policy_version_id") @db.Uuid
  siteCreditRateVersionId    String?                @map("site_credit_rate_version_id") @db.Uuid
  providerCostSnapshotId     String?                @unique @map("provider_cost_snapshot_id") @db.Uuid
  chargingMode               String                 @map("charging_mode")
  status                     String
  estimatedProviderNanoUsd   BigInt                 @default(0) @map("estimated_provider_nano_usd")
  quotedCreditMicros         BigInt                 @default(0) @map("quoted_credit_micros")
  reservedCreditMicros       BigInt                 @default(0) @map("reserved_credit_micros")
  finalProviderNanoUsd       BigInt?                @map("final_provider_nano_usd")
  finalCustomerNanoUsd       BigInt?                @map("final_customer_nano_usd")
  finalCreditMicros          BigInt?                @map("final_credit_micros")
  failureReason              String?                @map("failure_reason")
  createdAt                  DateTime               @default(now()) @map("created_at") @db.Timestamptz(3)
  settledAt                  DateTime?              @map("settled_at") @db.Timestamptz(3)
  generationRequest          GenerationRequest      @relation(fields: [generationRequestId], references: [id], onDelete: Restrict)
  tenant                     Workspace              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                       User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  providerPriceVersion       ProviderPriceVersion?  @relation(fields: [providerPriceVersionId], references: [id], onDelete: Restrict)
  markupPolicyVersion        MarkupPolicyVersion?   @relation(fields: [markupPolicyVersionId], references: [id], onDelete: Restrict)
  siteCreditRateVersion      SiteCreditRateVersion? @relation(fields: [siteCreditRateVersionId], references: [id], onDelete: Restrict)
  providerCostSnapshot       ProviderCostSnapshot?  @relation(fields: [providerCostSnapshotId], references: [id], onDelete: Restrict)
  ledgerEntries              CreditLedgerEntry[]

  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@map("credit_reservations")
}

model CreditLedgerEntry {
  id                         String             @id @db.Uuid
  accountId                  String             @map("account_id") @db.Uuid
  tenantId                   String             @map("tenant_id") @db.Uuid
  userId                     String?            @map("user_id") @db.Uuid
  reservationId              String?            @map("reservation_id") @db.Uuid
  generationRequestId        String?            @map("generation_request_id") @db.Uuid
  saleId                     String?            @map("sale_id") @db.Uuid
  welcomeCreditPolicyVersionId String?          @map("welcome_credit_policy_version_id") @db.Uuid
  type                       String
  availableDeltaCreditMicros BigInt             @map("available_delta_credit_micros")
  reservedDeltaCreditMicros  BigInt             @map("reserved_delta_credit_micros")
  availableAfterCreditMicros BigInt             @map("available_after_credit_micros")
  reservedAfterCreditMicros  BigInt             @map("reserved_after_credit_micros")
  idempotencyKey             String             @unique @map("idempotency_key")
  metadata                   Json?
  createdAt                  DateTime           @default(now()) @map("created_at") @db.Timestamptz(3)
  account                    CreditAccount      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  tenant                     Workspace          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                       User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  reservation               CreditReservation? @relation(fields: [reservationId], references: [id], onDelete: Restrict)
  fundedCreditSale          CreditSale?         @relation("CreditSaleFunding")
  creditSale                CreditSale?         @relation("CreditSaleLedger", fields: [saleId], references: [id], onDelete: Restrict)
  welcomeCreditPolicyVersion WelcomeCreditPolicyVersion? @relation(fields: [welcomeCreditPolicyVersionId], references: [id], onDelete: Restrict)

  @@index([tenantId, createdAt])
  @@index([reservationId])
  @@index([saleId])
  @@index([welcomeCreditPolicyVersionId])
  @@map("credit_ledger_entries")
}

model CreditPack {
  id                   String            @id @db.Uuid
  code                 String
  version              Int
  name                 String
  currency             String            @default("USD") @db.Char(3)
  unitAmount           BigInt            @map("unit_amount")
  creditsGrantedMicros BigInt            @map("credits_granted_micros")
  stripePriceId        String?           @unique @map("stripe_price_id")
  taxBehavior          String            @default("exclusive") @map("tax_behavior")
  status               String            @default("draft")
  activeFrom           DateTime?         @map("active_from") @db.Timestamptz(3)
  activeUntil          DateTime?         @map("active_until") @db.Timestamptz(3)
  createdAt            DateTime          @default(now()) @map("created_at") @db.Timestamptz(3)
  sales                CreditSale[]

  @@unique([code, version])
  @@index([status, activeFrom, activeUntil])
  @@map("credit_packs")
}

model PaymentCustomer {
  id                  String    @id @db.Uuid
  tenantId            String    @map("tenant_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  processor           String    @default("stripe")
  processorCustomerId String    @unique @map("processor_customer_id")
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant              Workspace @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, processor])
  @@index([userId])
  @@map("payment_customers")
}

model CreditSale {
  id                     String             @id @db.Uuid
  tenantId               String             @map("tenant_id") @db.Uuid
  customerUserId         String             @map("customer_user_id") @db.Uuid
  creditPackId           String?            @map("credit_pack_id") @db.Uuid
  cashAmountNanoUsd      BigInt             @map("cash_amount_nano_usd")
  creditsPurchasedMicros BigInt           @map("credits_purchased_micros")
  creditsGranted         BigInt             @map("credits_granted_micros")
  currency               String             @default("USD") @db.Char(3)
  paymentProvider        String             @map("payment_provider")
  processor              String
  processorCustomerId    String?            @map("processor_customer_id")
  processorCheckoutSessionId String?         @unique @map("processor_checkout_session_id")
  processorPaymentIntentId String?           @unique @map("processor_payment_intent_id")
  externalPaymentId      String?            @unique @map("external_payment_id")
  subtotalAmount         BigInt             @map("subtotal_amount")
  taxAmount              BigInt             @default(0) @map("tax_amount")
  totalAmount            BigInt             @map("total_amount")
  refundedAmount         BigInt             @default(0) @map("refunded_amount")
  creditsReversed        BigInt             @default(0) @map("credits_reversed_micros")
  refundResolutionRequired Boolean          @default(false) @map("refund_resolution_required")
  status                 String             @default("pending")
  creditLedgerEntryId    String?            @unique @map("credit_ledger_entry_id") @db.Uuid
  recordedByAdminId      String?            @map("recorded_by_admin_id") @db.Uuid
  notes                  String?
  occurredAt             DateTime           @map("occurred_at") @db.Timestamptz(3)
  paidAt                 DateTime?           @map("paid_at") @db.Timestamptz(3)
  refundedAt             DateTime?           @map("refunded_at") @db.Timestamptz(3)
  createdAt              DateTime            @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt              DateTime            @updatedAt @map("updated_at") @db.Timestamptz(3)
  tenant                 Workspace           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  customerUser           User                @relation("CreditSaleCustomer", fields: [customerUserId], references: [id], onDelete: Restrict)
  recordedByAdmin        User?               @relation("CreditSaleRecorder", fields: [recordedByAdminId], references: [id], onDelete: Restrict)
  creditPack             CreditPack?         @relation(fields: [creditPackId], references: [id], onDelete: Restrict)
  creditLedgerEntry      CreditLedgerEntry?  @relation("CreditSaleFunding", fields: [creditLedgerEntryId], references: [id], onDelete: Restrict)
  ledgerEntries          CreditLedgerEntry[] @relation("CreditSaleLedger")
  checkoutAttempts       CheckoutAttempt[]
  paymentEvents          PaymentEvent[]

  @@index([tenantId, occurredAt])
  @@index([customerUserId, occurredAt])
  @@map("credit_sales")
}

model CheckoutAttempt {
  id                         String     @id @db.Uuid
  saleId                     String     @map("sale_id") @db.Uuid
  tenantId                   String     @map("tenant_id") @db.Uuid
  userId                     String     @map("user_id") @db.Uuid
  processor                  String     @default("stripe")
  idempotencyKey             String     @unique @map("idempotency_key")
  processorCheckoutSessionId String?    @unique @map("processor_checkout_session_id")
  checkoutUrl                String?    @map("checkout_url")
  status                     String     @default("pending")
  error                      Json?
  createdAt                  DateTime   @default(now()) @map("created_at") @db.Timestamptz(3)
  completedAt                DateTime?  @map("completed_at") @db.Timestamptz(3)
  sale                       CreditSale @relation(fields: [saleId], references: [id], onDelete: Restrict)
  tenant                     Workspace  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user                       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([saleId, createdAt])
  @@index([tenantId, createdAt])
  @@map("checkout_attempts")
}

model PaymentEvent {
  id                String      @id @db.Uuid
  processor         String      @default("stripe")
  processorEventId  String      @unique @map("processor_event_id")
  processorObjectId String?     @map("processor_object_id")
  type              String
  saleId            String?     @map("sale_id") @db.Uuid
  payload           Json
  status            String      @default("received")
  error             String?
  receivedAt        DateTime    @default(now()) @map("received_at") @db.Timestamptz(3)
  processedAt       DateTime?   @map("processed_at") @db.Timestamptz(3)
  sale              CreditSale? @relation(fields: [saleId], references: [id], onDelete: Restrict)

  @@index([saleId, receivedAt])
  @@index([status, receivedAt])
  @@unique([processor, type, processorObjectId])
  @@map("payment_events")
}

model AdminAuditEvent {
  id          String    @id @db.Uuid
  actorUserId String    @map("actor_user_id") @db.Uuid
  tenantId    String?   @map("tenant_id") @db.Uuid
  action      String
  targetType  String    @map("target_type")
  targetId    String    @map("target_id")
  reason      String?
  before      Json?
  after       Json?
  requestId   String?   @map("request_id")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  actor       User      @relation("AdminAuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  tenant      Workspace? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([tenantId, createdAt])
  @@map("admin_audit_events")
}
