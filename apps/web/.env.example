PORT=3000
# Required locally and in production. The default matches the root compose.yaml service.
DATABASE_URL=postgresql://storyboard:storyboard@localhost:5432/storyboard
# Temporary local/test compatibility adapter. Do not use for production login.
AUTH_TOKENS=
ADMIN_OWNER_IDS=
PROJECT_MAX_FILES=500
PROJECT_MAX_BYTES=2147483648
GENERATION_CONCURRENCY=1
# Process-wide outbound provider admission: every provider has a FIFO lane with concurrency 1.
# The global value spaces request starts; override a lane with e.g. GEMINI_REQUEST_MIN_INTERVAL_MS.
PROVIDER_REQUEST_MIN_INTERVAL_MS=1000
# OPENAI_REQUEST_MIN_INTERVAL_MS=1000
# GEMINI_REQUEST_MIN_INTERVAL_MS=1000
# ELEVENLABS_REQUEST_MIN_INTERVAL_MS=1000
# Accounting and cost snapshots remain enabled. This independently controls
# real tenant credit movements and must stay false until pricing is approved.
BILLING_CUSTOMER_CHARGING_ENABLED=false
# Stripe-hosted one-time credit-pack Checkout. PUBLIC_APP_URL is used for
# success/cancel redirects and must be the externally reachable app origin.
PUBLIC_APP_URL=http://localhost:3000
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-3.5-flash
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1
# Server-authoritative output defaults. Keep the modality-specific aspect ratios during the
# migration; setting MEDIA_DEFAULT_ASPECT_RATIO applies one shared ratio to images and videos.
MEDIA_DEFAULT_ASPECT_RATIO=
MEDIA_IMAGE_DEFAULT_ASPECT_RATIO=1:1
MEDIA_IMAGE_DEFAULT_RESOLUTION_TIER=standard
MEDIA_IMAGE_DEFAULT_QUALITY=medium
MEDIA_VIDEO_DEFAULT_ASPECT_RATIO=4:3
MEDIA_VIDEO_DEFAULT_RESOLUTION_TIER=draft
DEZGO_API_KEY=
DEZGO_GUIDANCE=7
DEZGO_STEPS=25
DEZGO_SAMPLER=euler_a
TEXT_PROVIDER_TIMEOUT_MS=60000
IMAGE_PROVIDER_TIMEOUT_MS=180000
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5
ELEVENLABS_OUTPUT_FORMAT=pcm_24000
AUDIO_PROVIDER_TIMEOUT_MS=60000
PIPER_BINARY_PATH=
PIPER_VOICE_IDS=en_US-lessac-medium,en_US-amy-medium,en_US-ryan-medium,en_US-hfc_female-medium,en_US-hfc_male-medium,en_GB-alan-medium,en_GB-jenny_dioco-medium
SPARK_TTS_URL=http://localhost:8001
SPARK_TTS_TIMEOUT_MS=120000
# Must match SPARK_SERVICE_TOKEN in apps/voice-service/.env — this app is the client, that one is the server.
SPARK_SERVICE_TOKEN=
ALIGNMENT_SERVICE_URL=http://localhost:8002
ALIGNMENT_SERVICE_TIMEOUT_MS=60000
# Must match ALIGNMENT_SERVICE_TOKEN in apps/alignment-service/.env — this app is the client, that one is the server.
ALIGNMENT_SERVICE_TOKEN=
LTX_VIDEO_URL=http://localhost:8000
# Default provider used when a video request does not select one explicitly. Implemented: ltx,
# minimax, veo (scaffold, not live-validated), stub.
VIDEO_PROVIDER=ltx
# Optional; must match API_TOKEN on the LTX service when authentication is enabled.
LTX_VIDEO_API_TOKEN=
LTX_SHARED_DIR=/home/administrator/web/ltx-env/io/basic-cartoon-poc
# How often the server polls pending async video provider attempts (e.g. MiniMax) to completion.
VIDEO_RECONCILE_INTERVAL_MS=30000
MINIMAX_API_KEY=
MINIMAX_API_HOST=https://api.minimax.io
MINIMAX_VIDEO_MODEL=MiniMax-Hailuo-02
# Retry transient MiniMax RPM throttles (provider response code 1002) with exponential backoff.
MINIMAX_RATE_LIMIT_MAX_ATTEMPTS=4
MINIMAX_RATE_LIMIT_RETRY_MS=5000
# Veo video provider (second commercial provider, architectural scaffold, not yet live-validated).
# Uses the same GEMINI_API_KEY configured above for still-image/text generation.
VEO_API_HOST=https://generativelanguage.googleapis.com
VEO_VIDEO_MODEL=veo-3.1-generate-preview
# Optional global override. Without it, motion presets use 33/49/65 frames.
# LTX frame counts must satisfy (frames - 1) % 8 == 0.
VIDEO_FRAMES=
VIDEO_FRAME_RATE=24
# guidance_scale=4 was found to cause rapid identity collapse (faces warping within ~1-2s) on
# image-to-video. Tested 2.0-2.5 guidance x 45/55 steps at 5s on a moving-face scene; 45 steps /
# 2.25 guidance had the best edge-retention score and held identity cleanly through 5s, with only
# cosmetic softening (no more steps helped, and 2.0 guidance reintroduced warping).
VIDEO_STEPS=45
VIDEO_GUIDANCE_SCALE=2.25
VIDEO_SEED=42
# Optional global override; otherwise the web service supplies a movement-first baseline.
VIDEO_MOTION_PROMPT=
VIDEO_PROVIDER_TIMEOUT_MS=600000
