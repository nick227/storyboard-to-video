PIPER_SERVICE_PORT=8003
# Must match PIPER_SERVICE_TOKEN in apps/web/.env — this is the server, that one is the client.
# If unset, the service stays usable for local dev (warns once at startup) but every real
# deploy (including Modal) must set this via a secret.
PIPER_SERVICE_TOKEN=
# Comma-separated Piper voice ids (must match rhasspy/piper-voices naming).
PIPER_VOICE_IDS=en_US-lessac-medium,en_US-amy-medium,en_US-ryan-medium,en_US-hfc_female-medium,en_US-hfc_male-medium,en_GB-alan-medium,en_GB-jenny_dioco-medium
# Optional overrides; defaults match local web vendor layout / Modal image layout.
# PIPER_BINARY_PATH=/path/to/piper
# PIPER_VOICES_DIR=/path/to/voices
