VOICE_SERVICE_PORT=8001
# Must match SPARK_SERVICE_TOKEN in apps/web/.env — this is the server, that one is the client.
# If unset, the service stays usable for local dev (warns once at startup) but every real
# deploy (including Modal) must set this via a secret.
SPARK_SERVICE_TOKEN=
# Empirically tuned defaults are the Spark-TTS library's own.
SPARK_TEMPERATURE=0.8
SPARK_TOP_K=50
SPARK_TOP_P=0.95
